OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Resonance

# For presentations: treat concerts from this date forward as bookable (YYYY-MM-DD).
DEMO_REFERENCE_DATE=2026-05-01

EMBED_MODEL=intfloat/multilingual-e5-small

TOP_CANDIDATES=20
TOP_CANDIDATES_MAX=50
CATALOG_SIM_BIAS_WEIGHT=0.28
CATALOG_QUARTET_WEIGHT=10.0

# Journey: llm (default) uses OpenRouter; heuristic repair is offline fallback without OPENROUTER_API_KEY
JOURNEY_SELECTOR=llm
JOURNEY_LLM_CANDIDATES=40
JOURNEY_LLM_MAX_ATTEMPTS=4
JOURNEY_LLM_JUDGE=1
LLM_STRUCTURED_INTENT=1
JOURNEY_REPAIR_POOL=80
JOURNEY_LOG_CANDIDATES=1
JOURNEY_LOG_CANDIDATES_TOP=20

# Spacing: preferred min (default 7d), hard floor 2d when JOURNEY_GAP_SOFT=1 (default)
JOURNEY_GAP_MIN_DAYS=7
JOURNEY_GAP_HARD_MIN_DAYS=2
JOURNEY_GAP_MAX_DAYS=75
JOURNEY_GAP_SOFT=1

# Venue: prefer ≥2 types when pool offers them; does not block when JOURNEY_VENUE_SOFT=1 (default)
JOURNEY_VENUE_SOFT=1

# OpenRouter for structured intent, journey curator/judge, query guard, and narrative
OPENROUTER_JOURNEY_MODEL=openai/gpt-4o-mini
