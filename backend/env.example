OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Resonance

# multilingual-E5 uses query:/passage: prefixes automatically when the model name contains "e5"
EMBED_MODEL=intfloat/multilingual-e5-small

TOP_CANDIDATES=20

# Spacing between successive dates (~4–6 weeks). If no quartet matches, the backend relaxes gaps automatically.
JOURNEY_GAP_MIN_DAYS=25
JOURNEY_GAP_MAX_DAYS=49

# Optional tuning (numeric only):
# FIRST_SEMANTIC_MAX_RANK=10
# LAST_SEMANTIC_MIN_RANK=9
